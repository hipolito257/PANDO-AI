# ── Database (Supabase) ───────────────────────────────────────────────────────
# Usa la URL del Transaction Pooler de Supabase (puerto 6543)
DATABASE_URL="postgresql://postgres.XXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_SECRET="genera-un-string-random-seguro-aqui"
AUTH_URL="https://TU-APP.vercel.app"
NEXTAUTH_URL="https://TU-APP.vercel.app"
NEXTAUTH_SECRET="genera-un-string-random-seguro-aqui"

# ── Vercel Blob (archivos de plantillas) ──────────────────────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_XXXXX"

# ── Anthropic (cada usuario pone su propia en la app) ────────────────────────
# Opcional: fallback si el usuario no tiene API key configurada
ANTHROPIC_API_KEY="sk-ant-..."
